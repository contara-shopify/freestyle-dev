{% schema %}
{
  "name": "Video Scroll",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    }
  ],
  "presets": [
    {
      "name": "Video Scroll"
    }
  ]
}
{% endschema %}

{% assign video_src = "https://cdn.shopify.com/videos/c/o/v/a4adcd6b0e024541979e0d10447df711.mp4" %}

<p>Depuración - URL capturada: "{{ video_src }}"</p>

{% if video_src and video_src != "" and video_src != " " %}
  <div id="set-height"></div>
  <p id="time"></p>
  <video id="v0" tabindex="0" autobuffer="autobuffer" preload="auto" poster="https://via.placeholder.com/1280x720">
    <source type="video/mp4" src="{{ video_src }}">
  </video>
{% else %}
  <p>Por favor, configura un video en la sección.</p>
{% endif %}

<p>URL del video: {{ settings.video_url }}</p>

<style>
#set-height {
  display: block;
}
#v0 {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
}
p {
  font-family: helvetica;
  font-size: 24px;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
    console.log("Video URL (desde Shopify):", "{{ settings.video_url }}");

    var playbackConst = 500, 
        setHeight = document.getElementById("set-height"), 
        vid = document.getElementById("v0"); 

    if (!vid || "{{ settings.video_url }}".trim() === "") {
        console.log("El elemento de video no se encontró o la URL es vacía.");
        return;
    }

    console.log("Video encontrado, esperando metadata...");
    
    vid.addEventListener("loadedmetadata", function () {
        console.log("Duración del video:", vid.duration);
        setHeight.style.height = Math.floor(vid.duration) * playbackConst + "px";
    });

    function scrollPlay() {  
        if (vid) {
            var frameNumber = window.pageYOffset / playbackConst;
            vid.currentTime = frameNumber;
            console.log("Frame actual:", frameNumber);
            window.requestAnimationFrame(scrollPlay);
        }
    }

    window.requestAnimationFrame(scrollPlay);
});
</script>