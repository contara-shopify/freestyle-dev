{% schema %}
{
  "name": "Video Scroll",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "URL del video",
      "info": "Ingresa la URL del video MP4"
    },
    {
      "type": "range",
      "id": "playback_speed",
      "min": 100,
      "max": 1000,
      "step": 50,
      "default": 500,
      "label": "Velocidad de reproducción",
      "info": "Números más bajos = reproducción más rápida"
    }
  ],
  "presets": [
    {
      "name": "Video Scroll"
    }
  ]
}
{% endschema %}

<div class="video-scroll-section">
  <div id="set-height"></div>
  <video id="scroll-video" tabindex="0" autobuffer="autobuffer" preload="preload">
    <source type="video/mp4" src="{{ section.settings.video_url }}">
  </video>
</div>

<style>
  .video-scroll-section {
    position: relative;
    width: 100%;
  }

  #set-height {
    display: block;
  }

  #scroll-video {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const frameNumber = 0;
    const playbackConst = 500;
    const setHeight = document.getElementById("set-height");
    const vid = document.getElementById('scroll-video');

    vid.addEventListener('loadedmetadata', function() {
      setHeight.style.height = Math.floor(vid.duration) * playbackConst + "px";
    });

    function scrollPlay(){  
      const frameNumber = window.pageYOffset/playbackConst;
      vid.currentTime = frameNumber;
      window.requestAnimationFrame(scrollPlay);
    }

    window.requestAnimationFrame(scrollPlay);
  });
</script>