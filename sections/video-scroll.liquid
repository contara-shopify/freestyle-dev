{% schema %}
{
  "name": "Video Scroll",
  "settings": [],
  "presets": [
    {
      "name": "Video Scroll"
    }
  ]
}
{% endschema %}

<div class="video-scroll-section">
  <div id="set-height"></div>
  <video id="scroll-video" tabindex="0" autobuffer="autobuffer" preload="preload">
    <source type="video/mp4" src="{{ 'https://cdn.shopify.com/videos/c/o/v/a4adcd6b0e024541979e0d10447df711.mp4' | asset_url }}">
  </video>
</div>

<style>
  .video-scroll-section {
    position: relative;
    width: 100%;
  }

  #set-height {
    display: block;
  }

  #scroll-video {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const frameNumber = 0;
    const playbackConst = 500;
    const setHeight = document.getElementById("set-height");
    const vid = document.getElementById('scroll-video');

    vid.addEventListener('loadedmetadata', function() {
      setHeight.style.height = Math.floor(vid.duration) * playbackConst + "px";
    });

    function scrollPlay(){  
      const frameNumber = window.pageYOffset/playbackConst;
      vid.currentTime = frameNumber;
      window.requestAnimationFrame(scrollPlay);
    }

    window.requestAnimationFrame(scrollPlay);
  });
</script>