<div class="py-16">
  <div class="flex justify-center items-center">
    <!-- Columna izquierda (50%) -->
    <div class="w-[50%] pr-8 space-y-8 flex flex-col items-center sticky top-0">
      {% if section.settings.logo_1 != blank %}
        <div class="logo-container">
          {{ section.settings.logo_1 | image_url: 'master' | file_url | svg_tag }}
        </div>
      {% endif %}

      {% if section.settings.logo_2 != blank %}
        <div class="logo-container">
          {{ section.settings.logo_2 | image_url: 'master' | file_url | svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <!-- Columna derecha (50%) -->
    <div class="w-[50%]">
      {% for block in section.blocks %}
        <div class="scroll-block flex items-center mb-[25px]">
          {% if block.settings.logo != blank %}
            <div class="logo-container">
              {{ block.settings.logo | image_url: 'master' | file_url | svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  /* Por defecto, el SVG tendrá su color original */
  .logo-container svg {
    transition: fill 0.5s ease-in-out;
    fill: black; /* Color predeterminado del SVG */
  }

  /* Cuando el SVG esté activo, cambiará al color #6638B7 */
  .logo-container.active svg {
    fill: #6638B7 !important;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const blocks = document.querySelectorAll('.scroll-block');
  
  function updateActiveBlock() {
    const viewportHeight = window.innerHeight;
    const triggerPoint = viewportHeight / 2;

    blocks.forEach(block => {
      const rect = block.getBoundingClientRect();
      const blockMiddle = rect.top + (rect.height / 2);
      
      if (blockMiddle <= triggerPoint && blockMiddle > 0) {
        blocks.forEach(b => {
          const container = b.querySelector('.logo-container');
          container.classList.remove('active');
        });
        
        const container = block.querySelector('.logo-container');
        container.classList.add('active');
      }
    });
  }
  
  if (blocks.length > 0) {
    blocks[0].querySelector('.logo-container').classList.add('active');
  }
  
  window.addEventListener('scroll', function() {
    requestAnimationFrame(updateActiveBlock);
  });

  updateActiveBlock();
});
</script>

{% schema %}
{
  "name": "Logo Feature Blocks",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_1",
      "label": "Logo Izquierdo 1"
    },
    {
      "type": "image_picker",
      "id": "logo_2",
      "label": "Logo Izquierdo 2"
    }
  ],
  "blocks": [
    {
      "type": "logo_block",
      "name": "Logo Block",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Feature Blocks",
      "blocks": [
        {
          "type": "logo_block"
        },
        {
          "type": "logo_block"
        },
        {
          "type": "logo_block"
        },
        {
          "type": "logo_block"
        }
      ]
    }
  ]
}
{% endschema %}
