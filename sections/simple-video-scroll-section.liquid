{% comment %}
  Basic Video Scroll Section - Based on the working implementation
{% endcomment %}

<style>
  .video-scroll {
    height: 600vh;
    position: relative;
  }

  .video-scroll .holder {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
  }

  .video-scroll video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-scroll .story {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    color: #f1f1f1;
  }

  .video-scroll .story div {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .video-scroll h3 {
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.25;
    max-width: 16ch;
  }

  @media (max-width: 720px) {
    .video-scroll h3 {
      font-size: 1.5rem;
    }
  }
</style>

<section class="video-scroll">
  <div class="holder">
    <video src="{{ section.settings.video | file_url }}" muted playsinline></video>
  </div>

  <div class="story">
    <div>
      <h3>{{ section.settings.text_1 }}</h3>
    </div>
    <div>
      <h3>{{ section.settings.text_2 }}</h3>
    </div>
    <div>
      <h3>{{ section.settings.text_3 }}</h3>
    </div>
    <div>
      <h3>{{ section.settings.text_4 }}</h3>
    </div>
    <div>
      <h3>{{ section.settings.text_5 }}</h3>
    </div>
    <div>
      <h3>{{ section.settings.text_6 }}</h3>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.video-scroll');
    const vid = section.querySelector('video');

    vid.pause();

    const scroll = () => {
      const distance = window.scrollY - section.offsetTop;
      const total = section.clientHeight - window.innerHeight;

      let percentage = distance / total;
      percentage = Math.max(0, percentage);
      percentage = Math.min(percentage, 1);

      if (vid.duration > 0) {
        vid.currentTime = vid.duration * percentage;
      }
    };

    scroll();
    window.addEventListener('scroll', scroll);
  });
</script>

{% schema %}
{
  "name": "Video Scroll",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "In the heart of Wildrise…"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "…where the breezes play."
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3",
      "default": "We embrace the call of the wild each day."
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Text 4",
      "default": "Untamed places stretch,"
    },
    {
      "type": "text",
      "id": "text_5",
      "label": "Text 5",
      "default": "vast and wide."
    },
    {
      "type": "text",
      "id": "text_6",
      "label": "Text 6",
      "default": "Whispering secrets of a world outside."
    }
  ],
  "presets": [
    {
      "name": "Video Scroll",
      "category": "Video"
    }
  ]
}
{% endschema %}