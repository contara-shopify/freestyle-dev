{% endcomment %}

<section class="vid">
  <div class="holder">
    <video src="{{ section.settings.video | file_url }}" muted playsinline></video>
  </div>

  <div class="story">
    <div>
      <h3>In the heart of Wildrise&hellip;</h3>
    </div>
    <div>
      <h3>&hellip;where the breezes play.</h3>
    </div>
    <div>
      <h3>We embrace the call of the wild each day.</h3>
    </div>
    <div>
      <h3>Untamed places stretch,</h3>
    </div>
    <div>
      <h3>vast and wide.</h3>
    </div>
    <div>
      <h3>Whispering secrets of a world outside.</h3>
    </div>
  </div>
</section>

<script>
  // Wait until the section is fully rendered and available in the DOM
  document.addEventListener('DOMContentLoaded', function() {
    // Use exactly the same selector as your working code
    const section = document.querySelector('section.vid');
    if (!section) {
      console.error('Video section not found');
      return;
    }
    
    const vid = section.querySelector('video');
    if (!vid) {
      console.error('Video element not found');
      return;
    }
    
    console.log('Video element found, pausing it');
    vid.pause();
    
    const scroll = () => {
      console.log('Scroll event triggered');
      const distance = window.scrollY - section.offsetTop;
      const total = section.clientHeight - window.innerHeight;
      
      let percentage = distance / total;
      percentage = Math.max(0, percentage);
      percentage = Math.min(percentage, 1);
      
      console.log(`Scroll percentage: ${percentage}`);
      
      if (vid.duration > 0) {
        console.log(`Setting video time to: ${vid.duration * percentage}`);
        vid.currentTime = vid.duration * percentage;
      } else {
        console.log('Video duration not available yet');
      }
    };
    
    console.log('Adding scroll event listener');
    scroll(); // Initial call
    window.addEventListener('scroll', scroll);
    
    // Make sure the video is loaded
    vid.addEventListener('loadedmetadata', function() {
      console.log('Video metadata loaded, duration:', vid.duration);
      scroll(); // Try again after metadata is loaded
    });
  });
</script>

<style>
  section.vid {
    height: 600vh;
    position: relative;
  }

  section.vid div.holder {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
  }

  section.vid video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  section.vid div.story {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    color: #f1f1f1;
  }

  section.vid div.story div {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  section.vid h3 {
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.25;
    max-width: 16ch;
    text-wrap: balance;
  }

  @media (max-width: 720px) {
    section.vid h3 {
      font-size: 1.5rem;
    }
  }
</style>

