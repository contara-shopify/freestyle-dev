{% comment %}
  New Scrolling Video Section
  - Features scroll-based video scrubbing
  - Separate desktop/mobile videos
  - Configurable content blocks with positioning
  - Automatic transitions between video blocks
{% endcomment %}

<div class="video-scroll-section" data-section-id="{{ section.id }}">
  <div class="video-container relative w-full" x-data="videoScroll()" x-init="initialize()">
    <div class="sticky-wrapper overflow-hidden">
      <div class="sticky top-0 h-screen flex items-center justify-center overflow-hidden">
        {% for block in section.blocks %}
          <div 
            class="video-block absolute inset-0 w-full h-full opacity-0 transition-opacity duration-500"
            data-block-id="{{ block.id }}"
            x-show="currentVideoIndex === {{ forloop.index0 }}"
            x-transition:enter="transition ease-in-out duration-500"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in-out duration-500"
            x-transition:leave-start="opacity-100" 
            x-transition:leave-end="opacity-0"
          >
            {% if block.settings.desktop_video != blank %}
              <video 
                class="desktop-video w-full h-full object-cover hidden md:block"
                muted
                playsinline
                preload="auto"
                data-video-index="{{ forloop.index0 }}"
                data-video-duration="{{ block.settings.video_duration }}"
              >
                <source src="{{ block.settings.desktop_video | file_url }}" type="video/mp4">
              </video>
            {% endif %}
            
            {% if block.settings.mobile_video != blank %}
              <video 
                class="mobile-video w-full h-full object-cover block md:hidden"
                muted
                playsinline
                preload="auto"
                data-video-index="{{ forloop.index0 }}"
                data-video-duration="{{ block.settings.video_duration }}"
              >
                <source src="{{ block.settings.mobile_video | file_url }}" type="video/mp4">
              </video>
            {% endif %}
            
            {% if block.settings.show_content %}
              <div 
                class="content-container absolute z-10 p-6 max-w-md {% if block.settings.content_max_width != blank %}max-w-{{ block.settings.content_max_width }}{% endif %}"
                style="
                  color: {{ block.settings.text_color }};
                  {% case block.settings.content_position %}
                    {% when 'top-left' %}
                      top: 5%; left: 5%;
                    {% when 'top-center' %}
                      top: 5%; left: 50%; transform: translateX(-50%);
                    {% when 'top-right' %}
                      top: 5%; right: 5%;
                    {% when 'middle-left' %}
                      top: 50%; left: 5%; transform: translateY(-50%);
                    {% when 'middle-center' %}
                      top: 50%; left: 50%; transform: translate(-50%, -50%);
                    {% when 'middle-right' %}
                      top: 50%; right: 5%; transform: translateY(-50%);
                    {% when 'bottom-left' %}
                      bottom: 5%; left: 5%;
                    {% when 'bottom-center' %}
                      bottom: 5%; left: 50%; transform: translateX(-50%);
                    {% when 'bottom-right' %}
                      bottom: 5%; right: 5%;
                  {% endcase %}
                "
              >
                <div class="text-{{ block.settings.content_alignment }}">
                  {% if block.settings.title != blank %}
                    <h2 class="text-3xl md:text-4xl font-bold mb-4">{{ block.settings.title }}</h2>
                  {% endif %}
                  
                  {% if block.settings.description != blank %}
                    <div class="mb-6">{{ block.settings.description }}</div>
                  {% endif %}
                  
                  {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
                    <a 
                      href="{{ block.settings.cta_url }}" 
                      class="inline-block px-6 py-3 font-medium rounded hover:opacity-90 transition-opacity"
                      style="background-color: {{ block.settings.cta_bg_color }}; color: {{ block.settings.cta_text_color }};"
                    >
                      {{ block.settings.cta_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    
    <!-- Spacer to create scroll area -->
    <div class="scroll-spacer" style="height: {{ section.blocks.size | times: 100 }}vh;"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Alpine === 'undefined') {
      console.error('Alpine JS is required for the video-scroll section');
      return;
    }
  });
  
  function videoScroll() {
    return {
      videos: [],
      currentVideoIndex: 0,
      totalVideos: {{ section.blocks.size }},
      scrollProgress: 0,
      sectionInView: false,
      scrollHeight: 0,
      observer: null,
      
      initialize() {
        // Cache elements
        const sectionEl = this.$el.closest('.video-scroll-section');
        const scrollSpacer = this.$el.querySelector('.scroll-spacer');
        const stickyWrapper = this.$el.querySelector('.sticky-wrapper');
        
        // Setup video elements
        this.collectVideoElements();
        
        // Set the sticky wrapper height to match viewport
        stickyWrapper.style.height = '100vh';
        
        // Set scroll height based on number of videos
        this.scrollHeight = window.innerHeight * this.totalVideos;
        scrollSpacer.style.height = this.scrollHeight + 'px';
        
        // Wait for videos to load
        this.waitForVideosToLoad().then(() => {
          // Set up intersection observer
          this.setupIntersectionObserver(sectionEl);
          
          // Set up scroll handler
          window.addEventListener('scroll', this.handleScroll.bind(this));
          window.addEventListener('resize', this.handleResize.bind(this));
          
          // Initial scroll check
          setTimeout(() => this.handleScroll(), 100);
        });
      },
      
      collectVideoElements() {
        const desktopVideos = Array.from(this.$el.querySelectorAll('.desktop-video'));
        const mobileVideos = Array.from(this.$el.querySelectorAll('.mobile-video'));
        
        this.videos = [];
        for (let i = 0; i < {{ section.blocks.size }}; i++) {
          this.videos.push({
            desktop: desktopVideos[i] || null,
            mobile: mobileVideos[i] || null,
            duration: parseFloat(
              (desktopVideos[i]?.dataset.videoDuration || 
               mobileVideos[i]?.dataset.videoDuration || 
               10)
            )
          });
        }
      },
      
      waitForVideosToLoad() {
        const promises = [];
        
        this.videos.forEach(videoSet => {
          if (videoSet.desktop) {
            promises.push(new Promise((resolve) => {
              if (videoSet.desktop.readyState >= 2) {
                resolve();
              } else {
                videoSet.desktop.addEventListener('loadeddata', () => resolve());
                videoSet.desktop.addEventListener('error', () => resolve());
              }
            }));
          }
          
          if (videoSet.mobile) {
            promises.push(new Promise((resolve) => {
              if (videoSet.mobile.readyState >= 2) {
                resolve();
              } else {
                videoSet.mobile.addEventListener('loadeddata', () => resolve());
                videoSet.mobile.addEventListener('error', () => resolve());
              }
            }));
          }
        });
        
        return Promise.all(promises);
      },
      
      setupIntersectionObserver(targetElement) {
        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            this.sectionInView = entry.isIntersecting;
            if (this.sectionInView) {
              this.handleScroll();
            }
          });
        }, { threshold: [0, 0.25, 0.5, 0.75, 1] });
        
        this.observer.observe(targetElement);
      },
      
      handleScroll() {
        if (!this.sectionInView) return;
        
        const sectionRect = this.$el.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        
        // Calculate how far we've scrolled into the section
        const scrolledPastTop = -sectionRect.top;
        const visibleSectionHeight = this.scrollHeight - viewportHeight;
        
        // Calculate progress through the section (0 to 1)
        this.scrollProgress = Math.max(0, Math.min(1, scrolledPastTop / visibleSectionHeight));
        
        // Determine which video should be active
        const videoProgress = this.scrollProgress * this.totalVideos;
        const newIndex = Math.min(this.totalVideos - 1, Math.floor(videoProgress));
        
        if (newIndex !== this.currentVideoIndex) {
          this.currentVideoIndex = newIndex;
        }
        
        // Calculate progress within the current video (0 to 1)
        const videoStartProgress = newIndex / this.totalVideos;
        const videoEndProgress = (newIndex + 1) / this.totalVideos;
        const normalizedProgress = 
          (this.scrollProgress - videoStartProgress) / 
          (videoEndProgress - videoStartProgress);
        
        this.updateVideoTime(normalizedProgress);
      },
      
      updateVideoTime(progress) {
        const videoData = this.videos[this.currentVideoIndex];
        if (!videoData) return;
        
        const { desktop, mobile, duration } = videoData;
        const targetTime = Math.max(0, Math.min(duration, progress * duration));
        const isMobile = window.innerWidth < 768;
        
        if (!isMobile && desktop && isFinite(desktop.duration)) {
          desktop.currentTime = Math.min(desktop.duration - 0.01, targetTime);
        } else if (isMobile && mobile && isFinite(mobile.duration)) {
          mobile.currentTime = Math.min(mobile.duration - 0.01, targetTime);
        }
      },
      
      handleResize() {
        // Recalculate dimensions on resize
        this.scrollHeight = window.innerHeight * this.totalVideos;
        const scrollSpacer = this.$el.querySelector('.scroll-spacer');
        scrollSpacer.style.height = this.scrollHeight + 'px';
        
        // Update video time after resize
        setTimeout(() => this.handleScroll(), 100);
      }
    };
  }
</script>

{% schema %}
{
  "name": "New Scrolling Video",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Video Block",
      "settings": [
        {
          "type": "video",
          "id": "desktop_video",
          "label": "Desktop Video"
        },
        {
          "type": "video",
          "id": "mobile_video",
          "label": "Mobile Video"
        },
        {
          "type": "range",
          "id": "video_duration",
          "min": 1,
          "max": 60,
          "step": 1,
          "unit": "s",
          "label": "Video Duration (seconds)",
          "default": 10
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "checkbox",
          "id": "show_content",
          "label": "Show Content",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA Text"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content Position",
          "options": [
            {
              "value": "top-left",
              "label": "Top Left"
            },
            {
              "value": "top-center",
              "label": "Top Center"
            },
            {
              "value": "top-right",
              "label": "Top Right"
            },
            {
              "value": "middle-left",
              "label": "Middle Left"
            },
            {
              "value": "middle-center",
              "label": "Middle Center"
            },
            {
              "value": "middle-right",
              "label": "Middle Right"
            },
            {
              "value": "bottom-left",
              "label": "Bottom Left"
            },
            {
              "value": "bottom-center",
              "label": "Bottom Center"
            },
            {
              "value": "bottom-right",
              "label": "Bottom Right"
            }
          ],
          "default": "middle-center"
        },
        {
          "type": "select",
          "id": "content_alignment",
          "label": "Content Text Alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "content_max_width",
          "label": "Content Max Width",
          "options": [
            {
              "value": "xs",
              "label": "Extra Small"
            },
            {
              "value": "sm",
              "label": "Small"
            },
            {
              "value": "md",
              "label": "Medium"
            },
            {
              "value": "lg",
              "label": "Large"
            },
            {
              "value": "xl",
              "label": "Extra Large"
            },
            {
              "value": "2xl",
              "label": "2XL"
            },
            {
              "value": "3xl",
              "label": "3XL"
            }
          ],
          "default": "md"
        },
        {
          "type": "header",
          "content": "Color Settings"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "cta_bg_color",
          "label": "CTA Background Color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "cta_text_color",
          "label": "CTA Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Scrolling Video",
      "blocks": [
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.video-scroll-section {
  position: relative;
  width: 100%;
}

.video-scroll-section .sticky-wrapper {
  position: relative;
  width: 100%;
  z-index: 2;
}

.video-scroll-section .scroll-spacer {
  position: relative;
}

.video-scroll-section .video-block video {
  pointer-events: none;
}
{% endstylesheet %}