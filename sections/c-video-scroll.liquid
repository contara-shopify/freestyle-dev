{% comment %}
  Full-Screen Video Scroll Section
  - Features scroll-based video scrubbing
  - Separate desktop/mobile videos
  - Configurable content blocks with positioning
  - Automatic transitions between video blocks
{% endcomment %}

<div 
  class="video-scroll-section relative w-full" 
  data-section-id="{{ section.id }}"
  data-section-type="video-scroll"
  x-data="videoScroll()"
  x-init="initialize()"
>
  {% for block in section.blocks %}
    <div 
      class="video-block absolute inset-0 w-full h-screen flex items-center justify-center opacity-0 transition-opacity duration-500"
      data-block-id="{{ block.id }}"
      :class="{'opacity-100': currentVideoIndex === {{ forloop.index0 }}}"
    >
      {% if block.settings.desktop_video != blank %}
        <video 
          class="desktop-video absolute inset-0 w-full h-full object-cover hidden md:block"
          muted
          playsinline
          preload="auto"
          data-video-index="{{ forloop.index0 }}"
          data-video-duration="{{ block.settings.video_duration }}"
        >
          <source src="{{ block.settings.desktop_video | file_url }}" type="video/mp4">
        </video>
      {% endif %}
      
      {% if block.settings.mobile_video != blank %}
        <video 
          class="mobile-video absolute inset-0 w-full h-full object-cover block md:hidden"
          muted
          playsinline
          preload="auto"
          data-video-index="{{ forloop.index0 }}"
          data-video-duration="{{ block.settings.video_duration }}"
        >
          <source src="{{ block.settings.mobile_video | file_url }}" type="video/mp4">
        </video>
      {% endif %}
      
      {% if block.settings.show_content %}
        <div 
          class="content-container absolute z-10 p-6 max-w-md {% if block.settings.content_max_width != blank %}max-w-{{ block.settings.content_max_width }}{% endif %} text-{{ block.settings.text_color }}"
          style="
            {% case block.settings.content_position %}
              {% when 'top-left' %}
                top: 5%; left: 5%;
              {% when 'top-center' %}
                top: 5%; left: 50%; transform: translateX(-50%);
              {% when 'top-right' %}
                top: 5%; right: 5%;
              {% when 'middle-left' %}
                top: 50%; left: 5%; transform: translateY(-50%);
              {% when 'middle-center' %}
                top: 50%; left: 50%; transform: translate(-50%, -50%);
              {% when 'middle-right' %}
                top: 50%; right: 5%; transform: translateY(-50%);
              {% when 'bottom-left' %}
                bottom: 5%; left: 5%;
              {% when 'bottom-center' %}
                bottom: 5%; left: 50%; transform: translateX(-50%);
              {% when 'bottom-right' %}
                bottom: 5%; right: 5%;
            {% endcase %}
          "
        >
          <div class="text-{{ block.settings.content_alignment }}">
            {% if block.settings.title != blank %}
              <h2 class="text-3xl md:text-4xl font-bold mb-4">{{ block.settings.title }}</h2>
            {% endif %}
            
            {% if block.settings.description != blank %}
              <div class="mb-6">{{ block.settings.description }}</div>
            {% endif %}
            
            {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
              <a href="{{ block.settings.cta_url }}" class="inline-block px-6 py-3 bg-{{ block.settings.cta_bg_color }} text-{{ block.settings.cta_text_color }} font-medium rounded hover:opacity-90 transition-opacity">
                {{ block.settings.cta_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  {% endfor %}
  
  <div class="scroll-container h-screen" style="height: {{ section.blocks.size | times: 100 }}vh;"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Alpine === 'undefined') {
      console.error('Alpine JS is required for the video-scroll section');
      return;
    }
  });
  
  function videoScroll() {
    return {
      videos: [],
      currentVideoIndex: 0,
      totalVideos: {{ section.blocks.size }},
      scrollProgress: 0,
      lastScrollTop: 0,
      initialize() {
        const self = this;
        
        // Initialize videos
        const desktopVideos = document.querySelectorAll('.desktop-video');
        const mobileVideos = document.querySelectorAll('.mobile-video');
        const allVideos = [...desktopVideos, ...mobileVideos];
        
        // Group videos by index
        this.videos = [];
        for (let i = 0; i < {{ section.blocks.size }}; i++) {
          this.videos.push({
            desktop: desktopVideos[i],
            mobile: mobileVideos[i],
            duration: parseFloat(desktopVideos[i]?.dataset.videoDuration || mobileVideos[i]?.dataset.videoDuration || 10)
          });
        }
        
        // Wait for videos to be loaded
        Promise.all(Array.from(allVideos).map(video => {
          if (!video) return Promise.resolve();
          return new Promise((resolve) => {
            if (video.readyState >= 2) {
              resolve();
            } else {
              video.addEventListener('loadeddata', () => resolve());
            }
          });
        })).then(() => {
          // Set up scroll handler
          window.addEventListener('scroll', this.handleScroll.bind(this));
          
          // Trigger initial position
          this.handleScroll();
        });
      },
      
      handleScroll() {
        const scrollContainer = document.querySelector('.scroll-container');
        const containerTop = scrollContainer.getBoundingClientRect().top;
        const containerHeight = scrollContainer.offsetHeight;
        const windowHeight = window.innerHeight;
        
        // Calculate overall progress (0 to 1)
        this.scrollProgress = Math.max(0, Math.min(1, -containerTop / (containerHeight - windowHeight)));
        
        // Determine which video should be active
        const sectionHeight = 1 / this.totalVideos;
        const newVideoIndex = Math.min(
          this.totalVideos - 1,
          Math.floor(this.scrollProgress / sectionHeight)
        );
        
        if (newVideoIndex !== this.currentVideoIndex) {
          this.currentVideoIndex = newVideoIndex;
        }
        
        // Calculate video progress for the current video
        const videoStartProgress = sectionHeight * this.currentVideoIndex;
        const videoEndProgress = sectionHeight * (this.currentVideoIndex + 1);
        const videoProgress = (this.scrollProgress - videoStartProgress) / (videoEndProgress - videoStartProgress);
        
        this.updateVideoFrame(videoProgress);
        
        this.lastScrollTop = window.pageYOffset || document.documentElement.scrollTop;
      },
      
      updateVideoFrame(progress) {
        const videoData = this.videos[this.currentVideoIndex];
        if (!videoData) return;
        
        const { desktop, mobile, duration } = videoData;
        const targetTime = Math.max(0, Math.min(duration, progress * duration));
        
        if (desktop && !isNaN(desktop.duration)) {
          desktop.currentTime = Math.min(desktop.duration - 0.01, targetTime);
        }
        
        if (mobile && !isNaN(mobile.duration)) {
          mobile.currentTime = Math.min(mobile.duration - 0.01, targetTime);
        }
      }
    }
  }
</script>

{% schema %}
{
  "name": "Video Scroll",
  "tag": "section",
  "class": "video-scroll-section",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Video Block",
      "settings": [
        {
          "type": "video",
          "id": "desktop_video",
          "label": "Desktop Video"
        },
        {
          "type": "video",
          "id": "mobile_video",
          "label": "Mobile Video"
        },
        {
          "type": "range",
          "id": "video_duration",
          "min": 1,
          "max": 60,
          "step": 1,
          "unit": "s",
          "label": "Video Duration (seconds)",
          "default": 10
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "checkbox",
          "id": "show_content",
          "label": "Show Content",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA Text"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA URL"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content Position",
          "options": [
            {
              "value": "top-left",
              "label": "Top Left"
            },
            {
              "value": "top-center",
              "label": "Top Center"
            },
            {
              "value": "top-right",
              "label": "Top Right"
            },
            {
              "value": "middle-left",
              "label": "Middle Left"
            },
            {
              "value": "middle-center",
              "label": "Middle Center"
            },
            {
              "value": "middle-right",
              "label": "Middle Right"
            },
            {
              "value": "bottom-left",
              "label": "Bottom Left"
            },
            {
              "value": "bottom-center",
              "label": "Bottom Center"
            },
            {
              "value": "bottom-right",
              "label": "Bottom Right"
            }
          ],
          "default": "middle-center"
        },
        {
          "type": "select",
          "id": "content_alignment",
          "label": "Content Text Alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "content_max_width",
          "label": "Content Max Width",
          "options": [
            {
              "value": "xs",
              "label": "Extra Small"
            },
            {
              "value": "sm",
              "label": "Small"
            },
            {
              "value": "md",
              "label": "Medium"
            },
            {
              "value": "lg",
              "label": "Large"
            },
            {
              "value": "xl",
              "label": "Extra Large"
            },
            {
              "value": "2xl",
              "label": "2XL"
            },
            {
              "value": "3xl",
              "label": "3XL"
            }
          ],
          "default": "md"
        },
        {
          "type": "header",
          "content": "Color Settings"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "cta_bg_color",
          "label": "CTA Background Color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "cta_text_color",
          "label": "CTA Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Scroll",
      "blocks": [
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.video-scroll-section {
  position: relative;
  overflow: hidden;
}

.video-block video {
  pointer-events: none;
}

.scroll-container {
  position: relative;
  z-index: 1;
  pointer-events: none;
}
{% endstylesheet %}